<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="{{ site.robots }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {% for fontStylesheet in site.fontStylesheets %}
    <link href="{{ fontStylesheet }}" rel="stylesheet" />
    {% endfor %}
    {% for stylesheetHref in stylesheets or [] %}
    <link rel="stylesheet" href="{{ stylesheetHref }}" />
    {% endfor %}
    <title>{{ title }}</title>
  </head>
  <body>
    {{ content | safe }}
    {% for scriptModule in scripts or [] %}
    <script type="module" src="{{ scriptModule }}"></script>
    {% endfor %}
  </body>
</html>
