---
layout: layouts/base.njk
title: MB Teile
stylesheets:
  - /assets/css/app.css
scripts:
  - /assets/js/main.js
permalink: /index.html
---
<main class="app">
  <header class="toolbar">
    <h1>MB Teile</h1>
    <div class="toolbar-actions">
      <label class="sr-only" for="search-input">Suche nach Nummer oder Name</label>
      <input
        id="search-input"
        class="search-input"
        type="search"
        placeholder="Suche nach Nummer oder Name"
      />
      <label class="filter-toggle" for="in-stock-only">
        <input id="in-stock-only" type="checkbox" />
        <span>Nur Lieferbar</span>
      </label>
      <button id="reload-btn" type="button">Sync</button>
      <a class="nav-link" href="/groups.html">Gruppenansicht</a>
    </div>
  </header>

  <h2 class="section-title">Teilekatalog für A309 und A310</h2>
  <p id="status" class="status-banner" role="status" aria-live="polite" aria-atomic="true">Bereit</p>

  <div class="table-wrap">
    <table aria-describedby="status">
      <caption class="sr-only">Teileliste mit Artikelnummer, Name, Preis, Lieferbarkeit und Link</caption>
      <thead>
        <tr>
          <th scope="col" data-sort-col="partNumber" aria-sort="ascending">
            <button
              class="sort-btn"
              data-sort-key="partNumber"
              type="button"
            >
              Artikelnummer
            </button>
          </th>
          <th scope="col">Name</th>
          <th scope="col" data-sort-col="price" aria-sort="none">
            <button class="sort-btn" data-sort-key="price" type="button">
              Preis
            </button>
          </th>
          <th scope="col" data-sort-col="availability" aria-sort="none">
            <button
              class="sort-btn"
              data-sort-key="availability"
              type="button"
            >
              Lieferbarkeit
            </button>
          </th>
          <th scope="col">Link</th>
        </tr>
      </thead>
      <tbody id="parts-tbody"></tbody>
    </table>
  </div>

  <footer class="app-footer">
    <div class="pagination">
      <button id="prev-page-btn" type="button">Zurück</button>
      <p id="page-info" class="page-info">Seite 0 / 0</p>
      <button id="next-page-btn" type="button">Weiter</button>
    </div>
    <nav class="footer-links" aria-label="Rechtliche Hinweise">
      <a href="/impressum/">Impressum</a>
    </nav>
  </footer>
</main>
